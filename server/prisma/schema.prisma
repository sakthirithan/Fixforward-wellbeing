generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String     @id @default(uuid())
  firebaseId String     @unique
  email      String     @unique
  name       String?
  createdAt  DateTime   @default(now())
  logs       DailyLog[]
}

model DailyLog {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  sleepScore  Int         
  mood        String      
  stressLevel String      
  hrv         Int?        
  riskScore   Int         @default(0)
  productivity Int         @default(3)
  caffeine     String      @default("None")
  activity     String      @default("None")
  loggedAt    DateTime   @default(now())
  analysis    AIAnalysis?
}

model AIAnalysis {
  id          String   @id @default(uuid())
  logId       String   @unique
  log         DailyLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  tasks       String[]
  suggestions String[]
  riskLevel   String   
  insight     String   
  warning     String?  
  actionPlan  String[] 
  createdAt   DateTime @default(now())
}
